<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:mc="sap.suite.ui.microchart">

  <VBox id="kpiRoot" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

    <!-- ══════════════════════════════════════════════════════════════════════════
         Barre de configuration : toujours visible, position fixe au-dessus des tiles
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <HBox id="kpiSettingsRow" justifyContent="End" alignItems="Center" class="sapUiTinyMarginBottom">
      <Button id="kpiSettingsBtn" icon="sap-icon://action-settings" type="Transparent"
              tooltip="{i18n>kpi_configure_tooltip}"/>
    </HBox>

    <!-- ══════════════════════════════════════════════════════════════════════════
         Ligne KPI : Tuiles numériques
         Par défaut seul "Montant à Risque" est visible.
         Le bouton engrenage ci-dessus ouvre un popover pour afficher/masquer les autres.
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <HBox id="kpiTilesRow" justifyContent="Start" alignItems="Center" wrap="Wrap"
          class="sapUiTinyMarginBottom">

      <GenericTile id="kpiTileRiskAmount" header="{i18n>kpi_amount_at_risk}" frameType="TwoByHalf" scope="Display"
                   class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
        <tileContent>
          <TileContent id="kpiTileRiskAmountContent">
            <content>
              <NumericContent id="kpiNumRiskAmount" value="{kpi>/riskAmountAtRisk}" scale="k"
                              indicator="Down" valueColor="Error" withMargin="false"/>
            </content>
          </TileContent>
        </tileContent>
      </GenericTile>

      <GenericTile id="kpiTileActive" visible="false" header="{i18n>kpi_active_count}" frameType="TwoByHalf" scope="Display"
                   class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
        <tileContent>
          <TileContent id="kpiTileActiveContent">
            <content>
              <NumericContent id="kpiNumActive" value="{kpi>/totalVendors}" scale=""
                              indicator="None" valueColor="Good" withMargin="false"/>
            </content>
          </TileContent>
        </tileContent>
      </GenericTile>

      <GenericTile id="kpiTileInactive" visible="false" header="{i18n>kpi_inactive_count}" frameType="TwoByHalf" scope="Display"
                   class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
        <tileContent>
          <TileContent id="kpiTileInactiveContent">
            <content>
              <NumericContent id="kpiNumInactive" value="{kpi>/inactiveVendors}" scale=""
                              indicator="None" valueColor="Critical" withMargin="false"/>
            </content>
          </TileContent>
        </tileContent>
      </GenericTile>

      <!-- Cachées définitivement (remplacées par les graphiques) -->
      <GenericTile id="kpiTileHighRisk" visible="false" header="{i18n>kpi_high_risk_count}" frameType="TwoByHalf" scope="Display">
        <tileContent>
          <TileContent id="kpiTileHighRiskContent">
            <content>
              <NumericContent id="kpiNumHighRisk" value="{kpi>/highRiskVendors}" scale=""
                              indicator="None" valueColor="Error" withMargin="false"/>
            </content>
          </TileContent>
        </tileContent>
      </GenericTile>

      <GenericTile id="kpiTileBlocked" visible="false" header="{i18n>kpi_blocked_pct_header}" frameType="TwoByHalf" scope="Display">
        <tileContent>
          <TileContent id="kpiTileBlockedContent" unit="%">
            <content>
              <NumericContent id="kpiNumBlocked" value="{kpi>/blockedPercentage}" scale=""
                              indicator="None" valueColor="Critical" withMargin="false"/>
            </content>
          </TileContent>
        </tileContent>
      </GenericTile>

    </HBox>

    <!-- ══════════════════════════════════════════════════════════════════════════
         Graphiques analytiques (InteractiveBarChart)
         color sur chaque barre = indicateur coloré à gauche du label
         Câblage des événements dans Component.js via _wireChartHandlers()
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <HBox id="kpiChartsRow" justifyContent="Start" alignItems="Start" wrap="Wrap" class="sapUiSmallMarginTop">

      <!-- ── Statut de blocage ───────────────────────────────────────────────── -->
      <Panel id="statusPanel" width="280px" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
             backgroundDesign="Translucent">
        <headerToolbar>
          <Toolbar id="statusToolbar" style="Clear" height="2.5rem">
            <core:Icon id="statusIcon" src="sap-icon://status-inactive" color="#0854A0" class="sapUiTinyMarginEnd"/>
            <Title id="statusTitle" text="{i18n>kpi_blocking_status}" level="H6" titleStyle="H6"/>
          </Toolbar>
        </headerToolbar>
        <content>
          <VBox id="statusChartBox" class="sapUiTinyMarginBeginEnd sapUiTinyMarginBottom">
            <mc:InteractiveBarChart id="statusBarChart" selectionEnabled="true">
              <mc:bars>
                <mc:InteractiveBarChartBar id="statusBarActif"   label="{i18n>kpi_status_active}"  value="{kpi>/activeCount}"  displayedValue="{kpi>/activeCount}"  color="Good"/>
                <mc:InteractiveBarChartBar id="statusBarBlocked" label="{i18n>kpi_status_blocked}" value="{kpi>/blockedCount}" displayedValue="{kpi>/blockedCount}" color="Error"/>
                <mc:InteractiveBarChartBar id="statusBarClosure" label="{i18n>kpi_status_closure}" value="{kpi>/closureCount}" displayedValue="{kpi>/closureCount}" color="Critical"/>
              </mc:bars>
            </mc:InteractiveBarChart>
          </VBox>
        </content>
      </Panel>

      <!-- ── Niveaux de risque ───────────────────────────────────────────────── -->
      <Panel id="riskPanel" width="280px" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
             backgroundDesign="Translucent">
        <headerToolbar>
          <Toolbar id="riskToolbar" style="Clear" height="2.5rem">
            <core:Icon id="riskIcon" src="sap-icon://alert" color="#BB0000" class="sapUiTinyMarginEnd"/>
            <Title id="riskTitle" text="{i18n>kpi_risk_levels}" level="H6" titleStyle="H6"/>
          </Toolbar>
        </headerToolbar>
        <content>
          <VBox id="riskChartBox" class="sapUiTinyMarginBeginEnd sapUiTinyMarginBottom">
            <mc:InteractiveBarChart id="riskBarChart" selectionEnabled="true">
              <mc:bars>
                <mc:InteractiveBarChartBar id="riskBarLow"    label="{i18n>kpi_risk_low}"    value="{kpi>/lowRiskCount}"    displayedValue="{kpi>/lowRiskCount}"    color="Good"/>
                <mc:InteractiveBarChartBar id="riskBarMedium" label="{i18n>kpi_risk_medium}"  value="{kpi>/mediumRiskCount}" displayedValue="{kpi>/mediumRiskCount}" color="Critical"/>
                <mc:InteractiveBarChartBar id="riskBarHigh"   label="{i18n>kpi_risk_high}"   value="{kpi>/highRiskVendors}" displayedValue="{kpi>/highRiskVendors}" color="Error"/>
              </mc:bars>
            </mc:InteractiveBarChart>
          </VBox>
        </content>
      </Panel>

      <!-- ── Analyse de l'inactivité ─────────────────────────────────────────── -->
      <Panel id="inactivityPanel" width="300px" class="sapUiTinyMarginBottom"
             backgroundDesign="Translucent">
        <headerToolbar>
          <Toolbar id="inactivityToolbar" style="Clear" height="2.5rem">
            <core:Icon id="inactivityIcon" src="sap-icon://time-entry-request" color="#E78C07" class="sapUiTinyMarginEnd"/>
            <Title id="inactivityTitle" text="{i18n>kpi_inactivity_analysis}" level="H6" titleStyle="H6"/>
          </Toolbar>
        </headerToolbar>
        <content>
          <VBox id="inactivityChartBox" class="sapUiTinyMarginBeginEnd sapUiTinyMarginBottom">
            <mc:InteractiveBarChart id="inactivityBarChart" selectionEnabled="true">
              <mc:bars>
                <mc:InteractiveBarChartBar id="inactivityBar0to6"   label="{i18n>kpi_inactivity_less6}"  value="{kpi>/inactivity0to6}"   displayedValue="{kpi>/inactivity0to6}"   color="Good"/>
                <mc:InteractiveBarChartBar id="inactivityBar6to12"  label="{i18n>kpi_inactivity_6to12}"  value="{kpi>/inactivity6to12}"  displayedValue="{kpi>/inactivity6to12}"  color="Critical"/>
                <mc:InteractiveBarChartBar id="inactivityBar12plus" label="{i18n>kpi_inactivity_more12}" value="{kpi>/inactivity12plus}" displayedValue="{kpi>/inactivity12plus}" color="Error"/>
              </mc:bars>
            </mc:InteractiveBarChart>
          </VBox>
        </content>
      </Panel>

    </HBox>

  </VBox>
</core:FragmentDefinition>
