{
    "namespace": "longTailVendorManagement",
    "entities": [
        {
            "name": "Vendors",
            "label": "Vendor",
            "associations": [
                {
                    "name": "PurchaseOrders",
                    "target": "PurchaseOrders",
                    "multiplicity": "many",
                    "backAssociation": "vendors"
                },
                {
                    "name": "Invoices",
                    "target": "Invoices",
                    "multiplicity": "many",
                    "backAssociation": "vendors"
                }
            ],
            "labelPlural": "Vendors",
            "elements": [
                {
                    "name": "ID",
                    "type": "UUID",
                    "key": true,
                    "label": ""
                },
                {
                    "name": "vendorID",
                    "type": "String(50)",
                    "label": "Vendor ID",
                    "additionalInfo": "Identifiant unique du fournisseur (clé primaire)",
                    "essentialElement": true,
                    "semanticKey": true
                },
                {
                    "name": "vendorName",
                    "type": "String(100)",
                    "label": "Vendor Name",
                    "additionalInfo": "Dénomination sociale du fournisseur",
                    "key": false,
                    "essentialElement": true
                },
                {
                    "name": "country",
                    "type": "String(3)",
                    "label": "Country",
                    "additionalInfo": "Pays d’origine du fournisseur (code ISO)",
                    "key": false,
                    "essentialElement": false
                },
                {
                    "name": "category",
                    "type": "String(50)",
                    "label": "Category",
                    "additionalInfo": "Catégorie d’achat (ex. IT, Logistique, Services…)",
                    "key": false,
                    "essentialElement": false
                },
                {
                    "name": "blockingStatus",
                    "type": "String(20)",
                    "label": "Blocking Status",
                    "additionalInfo": "Statut de blocage SAP actuel : Actif | Bloqué | En cours de clôture",
                    "key": false,
                    "essentialElement": false
                }
            ]
        },
        {
            "name": "PurchaseOrders",
            "label": "Purchase Order",
            "associations": [
                {
                    "name": "vendors",
                    "target": "Vendors",
                    "multiplicity": "one",
                    "isComposition": false
                }
            ],
            "labelPlural": "Purchase Orders",
            "elements": [
                {
                    "name": "ID",
                    "type": "UUID",
                    "key": true,
                    "label": ""
                },
                {
                    "name": "purchaseOrderID",
                    "type": "String(50)",
                    "label": "Purchase Order ID",
                    "additionalInfo": "Identifiant unique du bon de commande",
                    "essentialElement": true,
                    "semanticKey": true
                },
                {
                    "name": "vendorID",
                    "type": "String(50)",
                    "label": "Vendor ID",
                    "additionalInfo": "Référence au fournisseur associé",
                    "key": false,
                    "essentialElement": true
                },
                {
                    "name": "lastPODate",
                    "type": "Date",
                    "label": "Last PO Date",
                    "additionalInfo": "Date du dernier Bon de Commande enregistré pour ce fournisseur",
                    "key": false,
                    "essentialElement": false
                },
                {
                    "name": "totalPOAmount",
                    "type": "Decimal",
                    "label": "Total PO Amount",
                    "additionalInfo": "Montant total des PO sur les 12 derniers mois (devise entreprise)",
                    "isAmount": true,
                    "key": false,
                    "essentialElement": false
                }
            ]
        },
        {
            "name": "Invoices",
            "label": "Invoice",
            "associations": [
                {
                    "name": "vendors",
                    "target": "Vendors",
                    "multiplicity": "one",
                    "isComposition": false
                }
            ],
            "labelPlural": "Invoices",
            "elements": [
                {
                    "name": "ID",
                    "type": "UUID",
                    "key": true,
                    "label": ""
                },
                {
                    "name": "invoiceID",
                    "type": "String(50)",
                    "label": "Invoice ID",
                    "additionalInfo": "Identifiant unique de la facture",
                    "essentialElement": true,
                    "semanticKey": true
                },
                {
                    "name": "vendorID",
                    "type": "String(50)",
                    "label": "Vendor ID",
                    "additionalInfo": "Référence au fournisseur associé",
                    "key": false,
                    "essentialElement": true
                },
                {
                    "name": "lastInvoiceDate",
                    "type": "Date",
                    "label": "Last Invoice Date",
                    "additionalInfo": "Date de la dernière facture reçue",
                    "key": false,
                    "essentialElement": false
                }
            ]
        }
    ],
    "service": {
        "name": "longTailVendorManagementSrv",
        "path": "srv/service.cds"
    },
    "applications": [
        {
            "pages": [
                {
                    "type": "ListReport",
                    "entityType": "Vendors",
                    "listReportContent": {
                        "loadDataOnAppLaunch": "Enabled",
                        "tables": [
                            {
                                "title": "Vue principale des fournisseurs",
                                "id": "VendorsListReport",
                                "baseEntityType": "Vendors",
                                "columns": [
                                    "vendorID",
                                    "vendorName",
                                    "country",
                                    "category",
                                    "blockingStatus"
                                ]
                            }
                        ],
                        "filters": [
                            "country",
                            "category",
                            "blockingStatus"
                        ]
                    }
                },
                {
                    "type": "ObjectPage",
                    "entityType": "Vendors",
                    "objectPageContent": {
                        "tableSectionAssociations": [
                            "PurchaseOrders",
                            "Invoices"
                        ],
                        "sections": [
                            {
                                "title": "Purchase Orders",
                                "id": "purchaseOrdersSection",
                                "isTableSection": true,
                                "fields": [
                                    "PurchaseOrders/purchaseOrderID",
                                    "PurchaseOrders/vendorID",
                                    "PurchaseOrders/lastPODate",
                                    "PurchaseOrders/totalPOAmount"
                                ]
                            },
                            {
                                "title": "Invoices",
                                "id": "invoicesSection",
                                "isTableSection": true,
                                "fields": [
                                    "Invoices/invoiceID",
                                    "Invoices/vendorID",
                                    "Invoices/lastInvoiceDate"
                                ]
                            }
                        ],
                        "tabs": [
                            {
                                "id": "vendorDetailsTab",
                                "title": "Vendor Details",
                                "subsections": [
                                    "purchaseOrdersSection",
                                    "invoicesSection"
                                ]
                            }
                        ],
                        "chartSections": []
                    }
                }
            ],
            "name": "vendorManagementApp"
        }
    ]
}